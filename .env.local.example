# Copie este arquivo para .env.local e preencha com os valores do seu
# projeto Supabase (Dashboard → Settings → API)

NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=coloque-a-anon-key-aqui

# Só para rodar `npm run seed` no seu computador.
# NUNCA commitar, NUNCA colocar na Vercel.
SUPABASE_SERVICE_ROLE_KEY=coloque-a-service-role-key-aqui
